{"name":"Rapid-OCR图片识别","desc":"本地识别图片文字工具","code":"import io.github.mymonstercat.ocr.InferenceEngine\nimport io.github.mymonstercat.Model\nimport com.benjaminwan.ocrlibrary.OcrResult\nimport java.nio.file.Files\nimport java.nio.file.Path\nimport java.util.LinkedList\n\nInferenceEngine engine = InferenceEngine.getInstance(Model.ONNX_PPOCR_V4)\n\nList<String> contentList = new LinkedList<>()\nList<Path> tempFiles = new LinkedList<>()\n\ntry {\n    imageList.each { file ->\n        byte[] fileBytes = fileService.getBytes(file.fileId)\n        \n        // 直接创建临时文件（无需先建目录）\n        Path tempFile = Files.createTempFile(\"ocr-\", \".tmp\")\n        tempFiles.add(tempFile)  // 记录以便清理\n        \n        Files.write(tempFile, fileBytes)\n        \n        OcrResult result = engine.runOcr(tempFile.toString());\n        contentList.add(result?.strRes ?: \"\")  // 防止 null\n    }\n    \n    return String.join(\"\\n\", contentList)\n    \n} catch (Exception e) {\n    System.err.println(\"Error: ${e.message}\")\n    e.printStackTrace()\n} finally {\n    // 清理所有临时文件\n    tempFiles.each { path ->\n        try {\n            Files.deleteIfExists(path)\n        } catch (Exception ex) {\n            // 忽略删除失败（如已被删或权限问题）\n        }\n    }\n}","inputFieldList":[{"name":"imageList","type":"array","source":"reference","isRequired":true}],"initFieldList":[],"userId":"ee95e0e38acaad23bd73d9bea414a97d","isActive":true,"toolType":"CUSTOM","label":"content_handle","scope":"WORKSPACE","icon":"./tool/rapid_ocr/icon.png","folderId":"default","version":"1.0.0","id":"901a5015140e579df2d3f2f08a7fb6ac","createTime":1772173553000,"updateTime":1772174486404}