<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.maxkb4j.knowledge.mapper.GraphEntityParagraphMappingMapper">

    <select id="getParagraphIdsByEntityIds" resultType="java.lang.String">
        SELECT DISTINCT paragraph_id
        FROM graph_entity_paragraph_mapping
        WHERE entity_id IN
        <foreach item="eid" collection="entityIds" open="(" separator="," close=")">
            #{eid}
        </foreach>
    </select>

    <select id="getParagraphIdsByEntityIdsAndKnowledgeId" resultType="java.lang.String">
        SELECT DISTINCT paragraph_id
        FROM graph_entity_paragraph_mapping
        WHERE knowledge_id = #{knowledgeId}
        AND entity_id IN
        <foreach item="eid" collection="entityIds" open="(" separator="," close=")">
            #{eid}
        </foreach>
    </select>

</mapper>